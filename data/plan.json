        "title": "Pitch/Run 1a — Straight-Line Sprints",
        "summary": "All 100% efforts, min 1 min rest after each sprint.",
        "detail": "Warm up (10-15 mins). Straight-line sprint work, all 100% efforts, minimum 1 min rest after each sprint:\n• 2 x 20m\n• 2 x 30m\n• 2 x 40m\n• 2 x 60m"
      },
      "run1b": {
        "id": "runs.run1b",
        "kind": "run",
        "title": "Pitch/Run 1b — Intervals",
        "summary": "Pitch perimeters @ 75% pace. 6 sets.",
        "detail": "Pitch perimeters @ 75% effort (fast but comfortable). The 30s run should be a faster pace than the 60s.\n\n1 set = 60s run, 45s off, 30s run, 30s off, 60s run — then REST.\nRepeat for 6 sets.\n\nCan be done on a treadmill / track / street run."
      },
      "run2": {
        "id": "runs.run2",
        "kind": "run",
        "title": "Pitch/Run 2 — Penalty-Box Run",
        "summary": "6-yard, pen spot & full width. Fast pace. (Can be done with a ball.)",
        "detail": "Penalty width box run (can be done with a ball). 1 rep = 6-yard back to line → pen spot back to line → full width. 30s rest between sets. Each rep at fast pace.",
        "byWeek": { "2": "4 sets x 4 reps", "3": "5 sets x 4 reps", "4": "6 sets x 3 reps" }
      },
      "run3a": {
        "id": "runs.run3a",
        "kind": "run",
        "title": "Pitch/Run 3a — Slalom + Curved Sprints",
        "summary": "All 100% efforts.",
        "detail": "Warm up (10-15 mins). All 100% efforts.\n• Slalom sprint work: x8 reps, 1 min rest after each effort.\n• REST 4-5 mins.\n• Curved sprint work (around 1/2 the centre circle): x4 reps each side (8 in total)."
      },
      "run3b": {
        "id": "runs.run3b",
        "kind": "run",
        "title": "Pitch/Run 3b — Saltire Run",
        "summary": "Diagonal runs @ 80% pace, light jog recovery.",
        "detail": "Saltire run. 1 rep = diagonal run + recovery + diagonal run + recovery. Run @ 80% pace, light jog as the rest.",
        "byWeek": { "2": "6 x 2 reps", "3": "8 x 2 reps", "4": "6 x 3 reps" }
      },
      "run4": {
        "id": "runs.run4",
        "kind": "run",
        "title": "Pitch/Run 4 — Every Line and Back",
        "summary": "For time. Continuous sets.",
        "detail": "'Every Line and Back' — for time.\n5 sets x 3 mins continuous OR 4 sets x 4 mins continuous.\n2-3 mins rest between sets."
      },
